# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by docker-compose to create the DB and by the watchdog to connect.
POSTGRES_DB=watchdog
POSTGRES_USER=watchdog
POSTGRES_PASSWORD=changeme_use_a_strong_password_here

# ── Apify (Phase 2 — leave blank for Phase 1) ─────────────────────────────────
# Create your account at https://apify.com → Settings → Integrations → API tokens
APIFY_API_TOKEN=

# ── Discord Webhooks (M3 — leave blank for M1/M2) ─────────────────────────────
# Create webhooks: Discord server → channel settings → Integrations → Webhooks
# Channel: #urgent-deals (score >= 60)
DISCORD_URGENT_WEBHOOK_URL=
# Channel: #apartment-listings (score >= 30, batched every 5 minutes)
DISCORD_NORMAL_WEBHOOK_URL=
# Channel: #errors-alerts (source failures, circuit breaker events)
DISCORD_ERROR_WEBHOOK_URL=

# ── Log level (optional, default: info) ────────────────────────────────────────
# Set to 'debug' for verbose adapter output during development
LOG_LEVEL=info
